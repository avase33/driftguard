# --- Model -----------------------------------------------------------------
# gbdt (default, from scratch) | xgboost
DRIFTGUARD_MODEL=gbdt
DRIFTGUARD_ESTIMATORS=60
DRIFTGUARD_MAX_DEPTH=3
DRIFTGUARD_LR=0.3

# --- Registry --------------------------------------------------------------
# local (default) | mlflow
DRIFTGUARD_REGISTRY=local
DRIFTGUARD_REGISTRY_DIR=mlruns_local
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Streaming -------------------------------------------------------------
# memory (default) | kafka
DRIFTGUARD_BUS=memory
KAFKA_BROKERS=localhost:9092
DRIFTGUARD_TOPIC=transactions
DRIFTGUARD_PARTITIONS=4

# --- Drift detection (PSI) -------------------------------------------------
DRIFTGUARD_PSI_ALERT=0.2            # PSI >= this => feature drifted
DRIFTGUARD_DRIFT_FRACTION=0.3       # > this fraction of features => dataset drift
DRIFTGUARD_MONITOR_BATCH=500
DRIFTGUARD_AUTO_RETRAIN=true

# --- Alerting --------------------------------------------------------------
# DRIFTGUARD_WEBHOOK=https://api.github.com/repos/<owner>/<repo>/dispatches
# SLACK_WEBHOOK=https://hooks.slack.com/services/...
